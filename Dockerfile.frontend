# Multi-stage Dockerfile for Vite React app (optional)
# Place this at the repo root (adjust build path if your frontend is elsewhere)

FROM node:18-alpine AS build
WORKDIR /app

COPY package*.json ./
RUN npm ci --silent

COPY . .
RUN npm run build

FROM nginx:stable-alpine
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
